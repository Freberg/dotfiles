{
    "layer": "top",
    "position": "top",
    "mod": "dock",
    "exclusive": true,
    "passtrough": false,
    "gtk-layer-shell": true,
    "height": 0,
    "modules-left": [
        "custom/news_ticker_launcher",
        "hyprland/workspaces",
        "niri/workspaces",
        "custom/separator_left_1",
        "hyprland/window",
        "niri/window",
        "custom/separator_left_2",
        "custom/separator_left_end"
    ],
    "modules-center": [
    ],
    "modules-right": [
        "custom/separator_right_start",
        "tray",
        "custom/separator_right_1",
        "custom/devpod",
        "custom/docker",
        "custom/separator_right_2",
        "pulseaudio",
        "pulseaudio#microphone",
        "custom/separator_right_3",
        "battery",
        "custom/nixos",
        "custom/separator_right_4",
        "custom/vpn",
        "custom/network",
        "custom/separator_right_5",
        "clock"
    ],
    "custom/news_ticker_launcher": {
        "format": "{}",
        "exec": "~/.config/scripts/ui/news_ticker_panel.sh"
    },
    "hyprland/workspaces": {
        "on-click": "activate"
    },
    "hyprland/window": {
        "format": "{}",
        "rewrite": {
            "Mozilla Firefox": "ΌυΒ firefox",
            "(.*) έΑΦ Mozilla Firefox": "ΌυΒ $1",
            "(.*) - Chromium": "ΌυΒ $1",
            "(vim|nvim).*": "ΌθΖ $0",
            "docker.*": "≤░κρ $0 $1",
            "(lf|lfcd)": "≤░βΖ $0",
            "(top|htop|bashtop)": "≤▒Ο┤ $0",
            "(bash|zsh)": "ΌςΖ $0",
            "intellij - (.*)": "Όη╡ $1"
        }
    },
    "niri/window": {
        "format": "{}",
        "rewrite": {
            "Mozilla Firefox": "ΌυΒ firefox",
            "(.*) έΑΦ Mozilla Firefox": "ΌυΒ $1",
            "(.*) - Chromium": "ΌυΒ $1",
            "(vim|nvim).*": "ΌθΖ $0",
            "docker.*": "≤░κρ $0 $1",
            "(lf|lfcd)": "≤░βΖ $0",
            "(top|htop|bashtop)": "≤▒Ο┤ $0",
            "(bash|zsh)": "ΌςΖ $0",
            "intellij - (.*)": "Όη╡ $1"
        }
    },
    "tray": {
        "icon-size": 13,
        "tooltip": false,
        "spacing": 10
    },
    "custom/devpod": {
        "tooltip": true,
        "format": "ΌτΕ {}",
        "exec": "bash ~/.config/scripts/ui/devpod_status.sh",
        "on-click": "~/.config/scripts/ui/devpod_menu.sh",
        "return-type": "json",
        "interval": 10,
        "signal": 8
    },
    "custom/docker": {
        "tooltip": true,
        "format": "ΎΝΙ {}",
        "exec": "bash ~/.config/scripts/ui/docker_status.sh",
        "on-click": "~/.config/scripts/ui/docker_menu.sh",
        "return-type": "json",
        "interval": 10,
        "signal": 8
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "tooltip": false,
        "format-muted": "≤░ΨΒ Muted",
        "on-click": "pamixer -t",
        "on-scroll-up": "pamixer -i 5",
        "on-scroll-down": "pamixer -d 5",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΑξ",
            "headset": "ΎΑξ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "≤░ΨΑ", "≤░Χ╛"]
        }
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "tooltip": false,
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒ Muted",
        "on-click": "pamixer --default-source -t",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5",
        "scroll-step": 5
    },
    "battery": {
        "bat": "BAT0",
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-icons": {
            "charging": ["≤░λθ", "≤░λε", "≤░ΓΗ", "≤░ΓΘ", "≤░ΓΙ", "≤░λζ", "≤░ΓΚ", "≤░λη", "≤░ΓΛ", "≤░ΓΜ", "≤░ΓΖ"],
            "default": ["≤▒ΔΞ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΒ", "≤░Β╣"]
        }
    },
    "custom/nixos": {
        "tooltip": true,
        "return-type": "json",
        "exec": "bash ~/.config/scripts/ui/nixos_status.sh",
        "interval": 60
    },
    "custom/vpn": {
        "tooltip": true,
        "exec": "bash ~/.config/scripts/ui/vpn_status.sh",
        "on-click": "~/.config/scripts/ui/vpn_menu.sh",
        "return-type": "json",
        "interval": 10,
        "signal": 8
    },
    "custom/network": {
        "tooltip": true,
        "interval" : 10,
        "exec": "bash ~/.config/scripts/ui/network_status.sh",
        "on-click": "~/.config/scripts/ui/network_menu.sh",
        "return-type": "json",
        "interval": 10,
        "signal": 8
    },
    "clock": {
        "format": "ΎΑΩ {0:%R} ΎΒ│ {0:%Y-%m-%d}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
    },
    "custom/separator_left_1": {
        "exec": "~/.config/scripts/ui/separators.sh left",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator_left_2": {
        "exec": "~/.config/scripts/ui/separators.sh left",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator_left_end": {
        "format": "  ",
        "tooltip": false
    },
    "custom/separator_right_start": {
        "format": "  ",
       "tooltip": false
    },
    "custom/separator_right_1": {
        "exec": "~/.config/scripts/ui/separators.sh right",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator_right_2": {
        "exec": "~/.config/scripts/ui/separators.sh right",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator_right_3": {
        "exec": "~/.config/scripts/ui/separators.sh right",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator_right_4": {
        "exec": "~/.config/scripts/ui/separators.sh right",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator_right_5": {
        "exec": "~/.config/scripts/ui/separators.sh right",
        "interval": "once",
        "tooltip": false
    },
    "custom/separator_right_6": {
        "exec": "~/.config/scripts/ui/separators.sh right",
        "interval": "once",
        "tooltip": false
    }
}
